{
	"layer": "top",
	"position": "top",
	"height": 24,
	"spacing": 6,

	"modules-left": [
		"hyprland/workspaces",
		"tray",
		"custom/network"
	],

	"modules-center": [
		"clock"
	],

	"modules-right": [
		"custom/cpu",
		"custom/igpu",
		"custom/gpu",
		"custom/memory",
		"custom/nvme",
		"custom/layout",
		"backlight",
		"pulseaudio",
		"custom/volpopup",
		"custom/battery",
		"custom/batterypopup"
	],

	"hyprland/workspaces": {
		"format": "{icon}",
		"format-icons": {
			"1": "I",
			"2": "II",
			"3": "III",
			"4": "IV",
			"5": "V",
			"6": "VI",
			"7": "VII",
			"8": "VIII",
			"9": "IX",
			"10": "X",
			"urgent": "!"
		}
	},

	"tray": {
		"spacing": 6
	},

	"clock": {
		"interval": 60,
		"format": "{:%b %d %a  %H:%M}"
	},

	"custom/cpu": {
		"exec": "~/.config/polybar/scripts/cpu-intel.sh",
		"interval": 1
	},

	"custom/igpu": {
		"exec": "~/.config/polybar/scripts/igpu-intel.sh",
		"interval": 2
	},

	"custom/gpu": {
		"exec": "~/.config/polybar/scripts/gpu-nvidia.sh",
		"interval": 2
	},

	"custom/memory": {
		"exec": "~/.config/polybar/scripts/ram-swap-bar.sh | sed 's/%{[^}]*}//g'",
		"interval": 2
	},

	"custom/nvme": {
		"exec": "~/.config/polybar/scripts/nvme-samsung.sh | sed 's/%{[^}]*}//g'",
		"interval": 5
	},

	"custom/layout": {
		"exec": "hyprctl devices -j | jq -r '.keyboards[] | select(.main==true) | .active_keymap | ascii_upcase'",
		"interval": 1,
		"on-click": "~/.config/polybar/scripts/switch-layout.sh"
	},

	"backlight": {
		"device": "intel_backlight",
		"format": "󰃞 {percent}%"
	},

	"pulseaudio": {
		"scroll-step": 5,
		"on-click": "pavucontrol",
		"on-click-right": "~/.config/polybar/scripts/volume-pipewire.sh",
		"format": "{icon} {volume}%",
		"format-muted": "󰝟",
		"format-icons": {
			"default": ["󰸈", "󰕿", "󰖀", "󱄠", "󰕾"]
		}
	},

	"custom/volpopup": {
		"exec": "cat ~/.config/polybar/scripts/vol-popup",
		"interval": 1,
		"return-type": "json"
	},

	"custom/battery": {
		"exec": "~/.config/polybar/scripts/battery-master.sh | sed 's/%{[^}]*}//g'",
		"interval": 5,
		"on-click": "~/.config/polybar/scripts/battery-info.sh",
		"on-click-right": "~/.config/polybar/scripts/battery-popup.sh"
	},

	"custom/batterypopup": {
		"exec": "cat ~/.config/polybar/scripts/battery-popup | sed 's/%{[^}]*}//g'",
		"interval": 1
	},

	"custom/network": {
		"exec": "~/.config/polybar/scripts/wifi-smart.sh | sed 's/%{[^}]*}//g'",
		"interval": 2
	}
}
