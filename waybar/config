{
	"layer": "top",
	"position": "top",
	"height": 24,
	"spacing": 6,

	"modules-left": [
		"hyprland/workspaces",
		"tray",
		"custom/network"
	],

	"modules-center": [
		"clock"
	],

	"modules-right": [
		"custom/cpu",
		"custom/gpu",
		"custom/memory",
		"custom/nvme",
		"custom/layout",
		"backlight",
		"pulseaudio",
		"custom/volpopup",
		"custom/battery",
		"custom/batterypopup"
	],

	"hyprland/workspaces": {
		"format": "{icon}",
		"format-icons": {
			"1": "⏺",
			"2": "⏺",
			"3": "⏺",
			"4": "⏺",
			"5": "⏺",
			"urgent": "⭘"
		}
	},

	"tray": {
		"spacing": 6
	},

	"clock": {
		"interval": 60,
		"format": "{:%b %d %a  %H:%M}"
	},

	"custom/cpu": {
		"exec": "~/.config/waybar/scripts/cpu-intel.sh",
		"interval": 1
	},

	"custom/gpu": {
		"exec": "~/.config/waybar/scripts/gpu-nvidia.sh",
		"interval": 2
	},

	"custom/memory": {
		"exec": "~/.config/waybar/scripts/ram-swap-bar.sh | sed 's/%{[^}]*}//g'",
		"interval": 2
	},

	"custom/nvme": {
		"exec": "~/.config/waybar/scripts/nvme-samsung.sh | sed 's/%{[^}]*}//g'",
		"interval": 5
	},

	"custom/layout": {
		"exec": "hyprctl devices -j | jq -r '.keyboards[] | select(.main==true) | .active_keymap | ascii_upcase'",
		"interval": 1,
		"on-click": "~/.config/waybar/scripts/switch-layout.sh"
	},

	"backlight": {
		"device": "intel_backlight",
		"format": "✨ {percent}%"
	},

	"pulseaudio": {
		"scroll-step": 5,
		"on-click": "pavucontrol",
		"on-click-right": "~/.config/waybar/scripts/volume-pipewire.sh",
		"format": "{icon} {volume}%",
		"format-muted": "🔇",
		"format-icons": {
			"default": ["🔈", "🔉", "🔊"]
		}
	},

	"custom/volpopup": {
		"exec": "cat ~/.config/waybar/scripts/vol-popup",
		"interval": 1,
		"return-type": "json"
	},

	"custom/battery": {
		"exec": "~/.config/waybar/scripts/battery-master.sh | sed 's/%{[^}]*}//g'",
		"interval": 5,
		"on-click": "~/.config/waybar/scripts/battery-info.sh",
		"on-click-right": "~/.config/waybar/scripts/battery-popup.sh"
	},

	"custom/batterypopup": {
		"exec": "cat ~/.config/waybar/scripts/battery-popup | sed 's/%{[^}]*}//g'",
		"interval": 1
	},

	"custom/network": {
		"exec": "~/.config/waybar/scripts/wifi-smart.sh | sed 's/%{[^}]*}//g'",
		"interval": 2
	},
}
